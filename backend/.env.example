# Backend Environment Variables Example

# Port for the server to listen on
PORT=5000

# MongoDB Connection String (from MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/examguard?retryWrites=true&w=majority

# Secret key for JWT authentication (use a long random string)
JWT_SECRET=your_super_secret_key_here

# Frontend URL (for CORS - used to allow React app to connect)
# When deployed, set this to your Vercel/Netlify URL
FRONTEND_URL=http://localhost:3000

# Environment (development or production)
NODE_ENV=development

# ─── Email Alert Configuration (Gmail SMTP) ───────────────────────────
# Step 1: Enable 2-Factor Authentication on your Gmail account
# Step 2: Go to Google Account > Security > App Passwords
# Step 3: Create an App Password for 'Mail' (gives a 16-char password)
# Step 4: Fill in your Gmail address and that App Password below
# Step 5: Set ALERT_EMAIL_ENABLED=true to activate email alerts
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=ExamGuard Alerts <your_gmail@gmail.com>
ALERT_EMAIL_ENABLED=false
